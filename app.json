{
  "expo": {
    "name": "Fa-ray",
    "slug": "Fa-ray",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Fa-ray"
    },
    "android": {
      "package": "et.faray.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "92db9fc1-e49a-4187-9a1e-785b4f77a81b"
      }
    },
    "plugins": [
      ["@react-native-community/datetimepicker", {
        "android": {
          "datePicker": {
            "colorAccent": { "light": "#1A5C35" },
            "colorControlActivated": { "light": "#1A5C35" },
            "windowBackground": { "light": "#FFFFFF" }
          }
        }
      }]
    ]
  }
}
